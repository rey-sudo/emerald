ENV=dev

NAME=api-document
DEBUG=true
VERSION=1.0.0

HOST=0.0.0.0
PORT=8001
WORKERS=1

TIMEOUT=120
GRACEFUL_TIMEOUT=30
KEEP_ALIVE=5

DB_URL=postgres://user:password@localhost:5432/api_document

S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=documents


RUST_LOG=info
DATABASE_URL=postgres://user:password@localhost:5432/api_document
PG_MAX_CONNECTIONS=10
PG_ACQUIRE_TIMEOUT_SECS=30
PULSAR_URL=pulsar://localhost:6650
PULSAR_RECONNECT_DELAY_SECS=5
PULSAR_MAX_RETRIES=10
PULSAR_BATCH_SIZE=100
TOPIC_LIST=persistent://public/default/api-document.folder,persistent://public/default/api-document.document
BATCH_SIZE=50
POLL_INTERVAL=5