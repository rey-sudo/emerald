ENV=dev
NAME=editor-api
DEBUG=true
VERSION=1.0.0
HOST=0.0.0.0
PORT=8002
WORKERS=1
TIMEOUT=120
GRACEFUL_TIMEOUT=30
KEEP_ALIVE=5

#CONSUMER VARIABLES
POD_NAME=pod9898
RUST_LOG=info
DATABASE_URL=postgres://postgres:password@postgres_global:5432/editor_api
PG_MAX_CONNECTIONS=10
PG_ACQUIRE_TIMEOUT_SECS=30

PULSAR_URL=pulsar://broker:6650
PULSAR_RECONNECT_DELAY_SECS=5
PULSAR_MAX_RETRIES=10
PULSAR_BATCH_SIZE=100

BATCH_SIZE=50
POLL_INTERVAL=5

CONSUMER_GROUP=editor-api-consumer-group
CONSUMER_PREFIX=editor-api-consumer
CONSUMER_SUFFIX=1
TOPIC_LIST="persistent://public/default/folder.created,persistent://public/default/folder.updated,persistent://public/default/folder.deleted,persistent://public/default/document.created,persistent://public/default/document.updated,persistent://public/default/document.deleted"
TOPIC_TYPE_LIST=key-shared,key-shared,key-shared,key-shared,key-shared,key-shared