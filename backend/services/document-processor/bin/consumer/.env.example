REDIS_HOST=localhost
REDIS_PORT=6379
QUEUE_NAME=documentQueue



RUST_LOG=info

DATABASE_URL=postgres://postgres:password@postgres_global:5432/document_processor
PG_MAX_CONNECTIONS=10
PG_ACQUIRE_TIMEOUT_SECS=30

PULSAR_URL=pulsar://broker:6650
PULSAR_RECONNECT_DELAY_SECS=5
PULSAR_MAX_RETRIES=10
PULSAR_BATCH_SIZE=100
TOPIC_LIST=persistent://public/default/api-document.document
BATCH_SIZE=50
POLL_INTERVAL=5
CONSUMER_GROUP=worker-document-consumer-group
CONSUMER_PREFIX=worker-document-consumer
CONSUMER_SUFFIX=1
CONSUMER_SERVER_PORT=7080

AWS_ENDPOINT=http://localhost:8333
AWS_ACCESS_KEY_ID=-------------
AWS_SECRET_ACCESS_KEY=-----------------
AWS_REGION=us-east-1
S3_BUCKET=documents

